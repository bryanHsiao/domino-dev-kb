<?xml version='1.0' encoding='utf-8'?>
<agent name='agtQueryCount' xmlns='http://www.lotus.com/dxl' version='12.0' maintenanceversion='2.5'
 replicaid='REPLACE_WITH_DB_REPLICAID' hide='v3' publicaccess='false' designerversion='8.5.3'>
<trigger type='actionsmenu'/>
<documentset type='runonce'/><code event='options'><lotusscript>Option Public
Option Declare
%Include "lsconst.lss"

Dim gCatalogRebuilt As Boolean
</lotusscript></code><code event='initialize'><lotusscript>Sub Initialize
	On Error Goto errorHandler
	Dim session As New NotesSession
	Dim ws As New NotesUIWorkspace
	Dim db As NotesDatabase
	Set db = session.CurrentDatabase

	' 1. 選 view
	Dim viewNames() As String
	Dim i As Integer
	i = 0
	ForAll v In db.Views
		Redim Preserve viewNames(i)
		viewNames(i) = v.Name
		i = i + 1
	End ForAll
	If i = 0 Then
		Msgbox "此資料庫沒有 view", 48, "agtQueryCount"
		Exit Sub
	End If
	Dim pick As Variant
	pick = ws.Prompt(PROMPT_OKCANCELLIST, "選擇 view", "要查詢哪個 view？", viewNames(0), viewNames)
	If Isempty(pick) Then Exit Sub
	Dim viewName As String
	viewName = Cstr(pick)

	' 2. 直欄 programmatic name
	pick = ws.Prompt(PROMPT_OKCANCELEDIT, "直欄", "直欄 programmatic name：", "$123")
	If Isempty(pick) Then Exit Sub
	Dim colName As String
	colName = Cstr(pick)

	' 3. 日期區間
	pick = ws.Prompt(PROMPT_OKCANCELEDIT, "起日", "起日（含），格式 yyyy/mm/dd：", "2024/01/01")
	If Isempty(pick) Then Exit Sub
	Dim dtStart As String
	dtStart = Cstr(pick)
	pick = ws.Prompt(PROMPT_OKCANCELEDIT, "訖日", "訖日（不含），格式 yyyy/mm/dd：", "2024/02/01")
	If Isempty(pick) Then Exit Sub
	Dim dtEnd As String
	dtEnd = Cstr(pick)

	' 4. 比較型別（直欄輸出型別要跟查詢詞一致 — DQL 不自動轉型）
	Dim modes(1) As String
	modes(0) = "文字比較（直欄輸出文字，需補零 yyyy/mm/dd 格式）"
	modes(1) = "@dt 日期比較（直欄輸出日期時間型，自動帶 +08:00）"
	pick = ws.Prompt(PROMPT_OKCANCELLIST, "比較型別", "直欄輸出的是文字還是日期時間？", modes(0), modes)
	If Isempty(pick) Then Exit Sub

	' 5. 組 query
	Dim colRef As String
	colRef = "'" &amp; viewName &amp; "'." &amp; colName
	Dim query As String
	If Cstr(pick) = modes(0) Then
		query = "in ('" &amp; viewName &amp; "') and " &amp; colRef &amp; " &gt;= '" &amp; dtStart &amp; "' and " &amp; colRef &amp; " &lt; '" &amp; dtEnd &amp; "'"
	Else
		query = "in ('" &amp; viewName &amp; "') and " &amp; colRef &amp; " &gt;= @dt('" &amp; ToIso(dtStart) &amp; "') and " &amp; colRef &amp; " &lt; @dt('" &amp; ToIso(dtEnd) &amp; "')"
	End If

	' 6. 執行 + Explain 成本資訊
	Dim dq As NotesDominoQuery
	Set dq = db.CreateDominoQuery()
	dq.RefreshViews = True
	Dim coll As NotesDocumentCollection
	Set coll = ExecuteWithCatalogRepair(dq, query)
	Dim explainTxt As String
	explainTxt = dq.Explain(query)

	' 7. 輸出：Msgbox 摘要 + 完整 Explain 寫檔
	Dim outPath As String
	outPath = LogPath("agtQueryCount")
	Dim fileNum As Integer
	fileNum = Freefile
	Open outPath For Output As fileNum
	Print #fileNum, "執行時間：" &amp; Format$(Now, "yyyy/mm/dd hh:nn:ss")
	Print #fileNum, "資料庫：[" &amp; db.Server &amp; "] " &amp; db.FilePath
	Print #fileNum, "Query: " &amp; query
	Print #fileNum, "命中筆數：" &amp; Cstr(coll.Count)
	If gCatalogRebuilt Then Print #fileNum, "（本次查詢偵測到 design catalog 缺失/損毀，已自動 Rebuild 後重試成功）"
	Print #fileNum, ""
	Print #fileNum, "=== 白話解讀 ==="
	Print #fileNum, "你問的問題：在「" &amp; viewName &amp; "」這個 view 裡，找「" &amp; colName &amp; "」欄位值落在 " &amp; dtStart &amp; "（含）～ " &amp; dtEnd &amp; "（不含）的文件。"
	Print #fileNum, "DQL 的回答：命中 " &amp; Cstr(coll.Count) &amp; " 筆，實際執行 " &amp; GrabAfter(explainTxt, "Exec ") &amp; " 毫秒。"
	Print #fileNum, ""
	Print #fileNum, "三個關鍵數字（取自下方 Explain 第一行的總計）："
	Print #fileNum, "- ScannedDocs = " &amp; GrabAfter(explainTxt, "ScannedDocs ") &amp; "：全庫翻閱的文件數。0 = 完全靠 view 索引，效能最好；"
	Print #fileNum, "  數字很大 = DQL 放棄索引、改成一份一份翻文件（效能警訊，通常是直欄不符合索引條件）。"
	Print #fileNum, "- Entries = " &amp; GrabAfter(explainTxt, "Entries ") &amp; "：在 view 索引裡掃過的資料列數。"
	Print #fileNum, "- FoundDocs = " &amp; GrabAfter(explainTxt, "FoundDocs ") &amp; "：符合全部條件的文件數（= 命中筆數）。"
	If coll.Count = 0 Then
		Print #fileNum, ""
		Print #fileNum, "⚠ 命中 0 筆——最常見的原因排查順序："
		Print #fileNum, "1. 比較型別跟直欄輸出型別不符（DQL 不自動轉型、也不報錯）："
		Print #fileNum, "   直欄輸出文字 → 要選文字比較；直欄輸出日期時間 → 要選 @dt。選錯必定 0 筆。"
		Print #fileNum, "2. 區間內真的沒資料（換個確定有資料的區間對照）。"
		Print #fileNum, "3. view 的 selection formula 把文件篩掉了（非 SELECT @All 的 view 要注意）。"
		Print #fileNum, "4. 直欄是混型（部分文件文字、部分日期）→ 單一型別的查詢只能抓到其中一半。"
	End If
	Print #fileNum, ""
	Print #fileNum, "下方 Explain 逐段怎麼看："
	Print #fileNum, "- 縮排結構 = 執行計畫的樹狀圖：0. AND 是總節點，底下每個 1. 是一個查詢條件。"
	Print #fileNum, "- 「IN ... View NoteID Extract」：第一步，把 view 裡的文件清單抓出來當搜尋範圍。"
	Print #fileNum, "- 「View Column Search」：用 view 直欄索引做範圍搜尋——看到它就代表有走索引。"
	Print #fileNum, "- 「estimated cost」：執行前的預估成本，DQL 拿它決定條件的執行順序（成本小的先跑）。"
	Print #fileNum, "  它是預估值、不是實際耗時；實際耗時看 Prep / Exec msecs。"
	Print #fileNum, "- 「(0 cost - coupled with earlier sibling)」：這個條件跟上一個條件合併一趟做完，所以顯示 0 成本。"
	Print #fileNum, "- 日期顯示成 ...Z（UTC）：Explain 會把 @dt 的 +08:00 換算成 UTC 顯示，屬正常現象、不是查錯時區。"
	Print #fileNum, ""
	Print #fileNum, "=== Explain（原始成本資訊）==="
	Print #fileNum, explainTxt
	Close fileNum

	Dim hint As String
	If coll.Count = 0 Then
		hint = Chr(10) &amp; Chr(10) &amp; "⚠ 0 筆最常見原因：比較型別與直欄輸出型別不符（DQL 不自動轉型也不報錯）。詳見結果檔的排查清單。"
	End If
	Msgbox "Query:" &amp; Chr(10) &amp; query &amp; Chr(10) &amp; Chr(10) &amp; _
	"命中筆數：" &amp; Cstr(coll.Count) &amp; hint &amp; Chr(10) &amp; Chr(10) &amp; _
	"完整成本計畫（Explain + 白話解讀）已寫入：" &amp; Chr(10) &amp; outPath, 64, "agtQueryCount"
	Exit Sub
errorHandler:
	If Err = 4854 Then
		Msgbox "DQL 錯誤（4854）：" &amp; Chr(10) &amp; Error$ &amp; Chr(10) &amp; Chr(10) &amp; _
		"對照診斷階梯：" &amp; Chr(10) &amp; _
		"- needs to be cataloged → load updall &lt;db&gt; -e" &amp; Chr(10) &amp; _
		"- View never built → 開一次該 view" &amp; Chr(10) &amp; _
		"- Partial TIMEDATEs → @dt 要完整 timestamp", 48, "agtQueryCount"
	Else
		Msgbox "錯誤 " &amp; Cstr(Err) &amp; "：" &amp; Error$ &amp; "（第 " &amp; Cstr(Erl) &amp; " 行）", 16, "agtQueryCount 錯誤"
	End If
	Exit Sub
End Sub

Function ToIso(d As String) As String
	' yyyy/m/d → yyyy-mm-ddT00:00:00+08:00（自動補零）
	Dim p As Variant
	p = Split(d, "/")
	ToIso = p(0) &amp; "-" &amp; Right("0" &amp; p(1), 2) &amp; "-" &amp; Right("0" &amp; p(2), 2) &amp; "T00:00:00+08:00"
End Function

Function LogPath(agentName As String) As String
	' log 歸檔：寫進專案 test-logs\&lt;agent&gt;\ 分類存放（時間戳檔名、不互相覆蓋）；
	' 資料夾不存在（如在別台機器跑）則 fallback 到 %TEMP%
	Dim logDir As String
	logDir = "C:\Users\siaob\code\20260716-dql-view-date-column-cast-research\test-logs\" &amp; agentName
	If Dir$(logDir, 16) = "" Then logDir = Environ("TEMP")
	LogPath = logDir &amp; "\" &amp; agentName &amp; "_" &amp; Format$(Now, "yyyymmdd-hhnnss") &amp; ".txt"
End Function

Function ExecuteWithCatalogRepair(dq As NotesDominoQuery, query As String) As NotesDocumentCollection
	' 正式環境模式（見 domino-news「DQL 正式環境筆記」）：
	' 查詢前 RefreshDesignCatalog（catalog 是新的時近乎零成本）；
	' 吃到「needs to be cataloged」的 4854 → RebuildDesignCatalog 重試一次。
	' 注意 Refresh 無法 bootstrap 全新 NSF，缺 catalog 必須 Rebuild。
	Dim rebuilt As Boolean
	On Error Goto execFail
	dq.RefreshDesignCatalog = True
	Set ExecuteWithCatalogRepair = dq.Execute(query)
	Exit Function
execFail:
	If Err = 4854 And Not rebuilt And Instr(Error$, "needs to be cataloged") &gt; 0 Then
		rebuilt = True
		gCatalogRebuilt = True
		dq.RebuildDesignCatalog = True
		Resume 0
	End If
	Error Err, Error$
End Function

Function GrabAfter(src As String, tag As String) As String
	' 從 Explain 文字抓 tag 後面的數字（取第一次出現，即總計那行）
	Dim p As Long
	Dim q As Long
	Dim c As String
	p = Instr(src, tag)
	If p = 0 Then
		GrabAfter = "?"
		Exit Function
	End If
	p = p + Len(tag)
	q = p
	Do While q &lt;= Len(src)
		c = Mid$(src, q, 1)
		If Instr("0123456789.", c) = 0 Then Exit Do
		q = q + 1
	Loop
	GrabAfter = Mid$(src, p, q - p)
End Function</lotusscript></code>
</agent>
